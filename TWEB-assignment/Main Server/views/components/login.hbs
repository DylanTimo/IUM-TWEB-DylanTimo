<div id="divLogin">
    <div>
        <div id="user"><i class="fas fa-user"></i></div>
        <label for="inputName" class="lambda-sr-only" style="display: none">Username</label>
        <input id="inputName" class="span2" type="text" name="username" placeholder="Username">
    </div>

    <div>
        <label for="inputPassword" class="lambda-sr-only" style="display: none">Password</label>
        <input id="inputPassword" class="span2" type="password" name="password" placeholder="Password">
    </div>

    <button type="submit" id="buttonSubmitLogin"><span class="lambda-sr-only">Login</span></button>
</div>

<div id = "divLoggedIn" style="display: none">
    <div class = "dropdown">
        <span id = "spanUsername">Guest</span>
    </div>
</div>

<div id = "divWaitingLogin" style="display: none">
    <span>Loading...</span>
</div>